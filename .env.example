# Laos Media – Sales Performance Panel Configuration

# API
API_PORT=4000
JWT_SECRET=provide_a_secure_random_secret
NODE_ENV=development
USE_MOCK_DATA=true

# DB
DB_HOST=localhost
DB_PORT=3306
DB_USER=laos
DB_PASSWORD=laos_password
DB_NAME=laos_sales

# Google Sheets
SHEETS_SPREADSHEET_ID=your_id_here
SHEETS_CLIENT_EMAIL=your_worker_account@project.iam.gserviceaccount.com
SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Column Mapping (0-based indices)
# Example alignment with typical Laos Media sheets:
# - Deals: Rep(0), Amount(1), Bonus(2), ID(3), Date(4)
# - Summary: Rep(0), Sales(1), BonusBase(2), Offset(3), Target(4)
SHEETS_COLUMN_MAPPING_JSON='{"deals":{"repName":0,"dealAmount":1,"bonus":2,"dealId":3,"dealDate":4},"summary":{"repName":0,"totalSalesAmount":1,"bonusBaseRaw":2,"offsetAmount":3,"targetAmount":4}}'

# Sync
SYNC_INTERVAL_MS=300000
